# Mass Apply — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API (required — for CV/letter generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase Auth (required — for user authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Adzuna Job API (optional — aggregates Indeed + 50 boards)
# Register at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Gemini API (optional — fallback for CV parsing)
GEMINI_API_KEY=

# Admin emails (comma-separated — skip onboarding, use hardcoded config)
ADMIN_EMAILS=
